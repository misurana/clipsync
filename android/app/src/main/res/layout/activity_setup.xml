<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 ClipSync"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Open the ClipSync web app on your laptop and scan the QR code it shows."
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="28dp" />

        <!-- Pairing status -->
        <TextView
            android:id="@+id/tv_pairing_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Not paired yet"
            android:textSize="14sp"
            android:textColor="@color/primary"
            android:fontFamily="monospace"
            android:layout_marginBottom="24dp" />

        <!-- Scan QR button -->
        <Button
            android:id="@+id/btn_scan_qr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scan QR Code"
            android:layout_marginBottom="12dp" />

        <!-- Enable keyboard button -->
        <Button
            android:id="@+id/btn_enable_keyboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable ClipSync Keyboard"
            android:layout_marginBottom="12dp" />

        <!-- Clear pairing -->
        <Button
            android:id="@+id/btn_clear_pairing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clear Pairing"
            android:enabled="false"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_marginBottom="24dp" />

        <!-- Instructions -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Steps:\n1. Open clipsync-web-phi.vercel.app on your laptop.\n2. A QR code will appear automatically.\n3. Tap &#34;Scan QR Code&#34; above and point your camera at the laptop screen.\n4. Set ClipSync as your default keyboard in Settings."
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingMultiplier="1.6"
            android:background="@color/surface"
            android:padding="16dp" />

    </LinearLayout>

</ScrollView>
